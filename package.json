{
  "name": "codystem-status",
  "version": "0.1.0",
  "private": true,
  "description": "Machine-checkable progress reporter for CODYSTEM tasks.md ledgers",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "codystem-status": "dist/cli.js"
  },
  "scripts": {
    "lint": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc -p tsconfig.json",
    "test": "node --test dist/ledger.test.js",
    "build": "tsc -p tsconfig.json",
    "status": "node dist/cli.js"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
